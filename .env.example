# Copy this file to .env and fill in real values.
# Never commit the real .env file.

# --- Database ---
DATABASE_URL=postgresql://subtitle_app:subtitle_app_password@localhost:5432/subtitle_app

# --- Redis / Queue ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO locally, S3/R2-compatible in production) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_password
S3_BUCKET=subtitle-app-media

# --- Providers ---
ASR_PROVIDER=mock
TRANSLATION_PROVIDER=mock

# --- Text-to-speech (ElevenLabs) ---
# Used by the API service for the /api/tts endpoints. Server-side only -
# never exposed to the browser. Get a key at elevenlabs.io.
ELEVENLABS_API_KEY=

# --- API ---
PORT=4000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=7200

# --- Object storage public endpoint (browser-accessible media URLs) ---
S3_PUBLIC_ENDPOINT=http://localhost:9000
